{
	"name": "liquiddesign/storm",
	"description": "ϟ StORM is lightweight PHP ORM library based on PDO",
	"license": "MIT",
	"autoload": {
		"psr-4": {"StORM\\": "src/"}
	},
	"require" :
	{
		"php": ">=7.3.0",
		"ext-pdo": "*",
		"ext-json": "*",
		"nette/di":"~3.0.0",
		"nette/caching":"~3.0.0",
		"tracy/tracy":"~2.7.0",
		"panique/pdo-debug": "~0.2"
	},
	"require-dev": 
	{
		"nette/tester":"*",
		"squizlabs/php_codesniffer": "3.*",
		"slevomat/coding-standard": "~4.0",
		"phpstan/phpstan": "*"
	},
	"scripts": {
		"phpstan": "phpstan analyse --level 5 src",
		"phpcs": "phpcs --standard=ruleset.xml src",
		"tester": "tester tests/*.phpt  -c tests/php.ini --setup tests/runner-setup.php"
	}
}